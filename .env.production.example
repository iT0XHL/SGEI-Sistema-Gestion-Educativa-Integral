# ============================================================
# SGEI — Variables de entorno de PRODUCCIÓN
# Copia este archivo como `.env` en el directorio de despliegue
# del VPS (junto a docker-compose.prod.yml) y completa los
# valores. NUNCA subas el `.env` real al repositorio.
# ============================================================

# ── Base de datos ────────────────────────────────────────────
POSTGRES_USER=sgei
POSTGRES_PASSWORD=CAMBIA-ESTA-CONTRASENA-SEGURA
POSTGRES_DB=sgei_db

# ── JWT (mínimo 64 caracteres aleatorios) ────────────────────
# Genera uno con: openssl rand -hex 48
JWT_SECRET=CAMBIA-ESTE-SECRETO-MINIMO-64-CARACTERES-ALEATORIOS
JWT_EXPIRES_IN=8h
JWT_COOKIE_NAME=sgei_token
BCRYPT_SALT_ROUNDS=12

# ── URLs públicas ────────────────────────────────────────────
# Origen del frontend tal como lo ve el navegador (CORS).
# Con IP:     http://123.45.67.89
# Con dominio: https://sgei.tudominio.com
FRONTEND_ORIGIN=http://TU_IP_O_DOMINIO

# Puertos publicados en el VPS
FRONTEND_PORT=80
BACKEND_PORT=3001

# ── Cookie de sesión ─────────────────────────────────────────
# true  → la cookie solo viaja por HTTPS (requiere dominio + SSL)
# false → permite login por HTTP plano (ej. acceso por IP sin SSL)
COOKIE_SECURE=false

# ── Archivos ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5

# Almacenamiento local — bind mount en ./uploads
STORAGE_PATH=/app/public/uploads
APP_URL=http://TU_IP_O_DOMINIO:3001

# ── Supabase Storage (opcional) ──────────────────────────────
# Solo si usas materiales/actividades/entregas con archivos.
# IMPORTANTE: no dejes SUPABASE_URL= vacío — el backend valida que
# sea una URL y no arrancaría. Si no usas Supabase, déjalos comentados.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...

# ── Imágenes (normalmente no hace falta tocarlas) ────────────
# BACKEND_IMAGE=ghcr.io/it0xhl/sgei-backend:latest
# FRONTEND_IMAGE=ghcr.io/it0xhl/sgei-frontend:latest
