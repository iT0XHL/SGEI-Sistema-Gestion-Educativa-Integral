  alumno         Alumno           @relation(fields: [alumno_id], references: [id], onUpdate: NoAction)
  registrador    Docente          @relation(fields: [registrado_por], references: [id], onUpdate: NoAction)
  seccion        Seccion          @relation(fields: [seccion_id], references: [id], onUpdate: NoAction)

  @@unique([alumno_id, seccion_id, fecha])
  @@index([alumno_id, fecha], map: "idx_asistencia_alumno")
  @@index([seccion_id, fecha], map: "idx_asistencia_fecha")
