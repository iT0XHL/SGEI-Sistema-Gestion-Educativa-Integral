  @@unique([actividad_id, alumno_id])
  @@index([actividad_id], map: "idx_entrega_actividad")
  @@index([alumno_id], map: "idx_entrega_alumno")
  @@index([estado], map: "idx_entrega_estado")
  @@map("entrega_actividad")
  @@schema("academic_schema")
}

model ConceptoPago {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String  @db.VarChar(80)
  descripcion String?
  monto_base  Decimal @db.Decimal(10, 2)
  activo      Boolean @default(true)
  pagos       Pago[]

  @@map("concepto_pago")
  @@schema("financial_schema")
}

model Pago {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alumno_id         String           @db.Uuid
  concepto_id       String           @db.Uuid
  periodo_id        String           @db.Uuid
  mes               Int?             @db.SmallInt
  monto             Decimal          @db.Decimal(10, 2)
  estado            EstadoPago       @default(Pendiente)
  fecha_vencimiento DateTime         @db.Date
  fecha_pago        DateTime?        @db.Date
  generado_por      String           @db.Uuid
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  boleta            BoletaPago?
  alumno            Alumno           @relation(fields: [alumno_id], references: [id], onUpdate: NoAction)
  concepto          ConceptoPago     @relation(fields: [concepto_id], references: [id], onUpdate: NoAction)
  generador         PerfilUsuario    @relation(fields: [generado_por], references: [id], onUpdate: NoAction)
  periodo           PeriodoAcademico @relation(fields: [periodo_id], references: [id], onUpdate: NoAction)

  @@index([alumno_id, estado, mes], map: "idx_pago_estado_alumno")
  @@index([fecha_vencimiento, estado], map: "idx_pago_vencimiento")
  @@map("pago")
  @@schema("financial_schema")
}

model BoletaPago {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pago_id             String               @unique @db.Uuid
  url_archivo         String
  nombre_archivo      String?              @db.VarChar(200)
  banco               String?              @db.VarChar(80)
  numero_operacion    String?              @db.VarChar(50)
  estado_revision     EstadoRevisionBoleta @default(En_Revision)
  observacion_rechazo String?
  revisado_por        String?              @db.Uuid
  fecha_revision      DateTime?            @db.Timestamptz(6)
  fecha_subida        DateTime             @default(now()) @db.Timestamptz(6)
  pago                Pago                 @relation(fields: [pago_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  revisor             PerfilUsuario?       @relation(fields: [revisado_por], references: [id], onUpdate: NoAction)

  @@index([estado_revision], map: "idx_boleta_estado")
  @@map("boleta_pago")
  @@schema("financial_schema")
}

model Notificacion {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuario_destino_id   String           @db.Uuid
  tipo                 TipoNotificacion
  titulo               String           @db.VarChar(150)
  cuerpo               String
  url_accion           String?
  leida                Boolean          @default(false)
  fecha_lectura        DateTime?        @db.Timestamptz(6)
  created_at           DateTime         @default(now()) @db.Timestamptz(6)
  actor_id             String?          @db.Uuid
  actor_rol            String?          @db.VarChar(20)
  actor_nombre_snapshot String?         @db.VarChar(150)
  evento               String?          @db.VarChar(50)
  entidad_tipo         String?          @db.VarChar(40)
  entidad_id           String?          @db.Uuid
  prioridad            String           @default("normal") @db.VarChar(10)
  metadata             Json?
  canal                String           @default("app") @db.VarChar(15)
  idempotency_key      String?          @unique @db.VarChar(200)
  archivada            Boolean          @default(false)
  expires_at           DateTime?        @db.Timestamptz(6)
  destino              PerfilUsuario    @relation(fields: [usuario_destino_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_destino_id, leida], map: "idx_notificacion_destino")
  @@index([evento], map: "idx_notificacion_evento")
  @@index([actor_id], map: "idx_notificacion_actor")
  @@index([entidad_tipo, entidad_id], map: "idx_notificacion_entidad")
  @@map("notificacion")
  @@schema("financial_schema")
}

model HistorialNota {
