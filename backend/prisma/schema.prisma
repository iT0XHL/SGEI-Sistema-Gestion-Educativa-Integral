generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["academic_schema", "audit_schema", "auth_schema", "financial_schema"]
}

model Credencial {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuario_login     String         @unique @db.VarChar(50)
  password_hash     String         @db.VarChar(255)
  nombres           String?        @db.VarChar(100)
  apellido_paterno  String?        @db.VarChar(60)
  apellido_materno  String?        @db.VarChar(60)
  activo            Boolean        @default(true)
  intentos_fallidos Int            @default(0) @db.SmallInt
  bloqueado_hasta   DateTime?      @db.Timestamptz(6)
  ultimo_acceso     DateTime?      @db.Timestamptz(6)
  debe_cambiar_password Boolean      @default(false)
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime       @default(now()) @db.Timestamptz(6)
  perfil            PerfilUsuario?
  tokens_recuperacion TokenRecuperacion[]

  @@index([usuario_login], map: "idx_credencial_login")
  @@map("credencial")
  @@schema("auth_schema")
}

model TokenRecuperacion {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  credencial_id String     @db.Uuid
  token_hash    String     @unique @db.VarChar(64)
  expira_en     DateTime   @db.Timestamptz(6)
  usado         Boolean    @default(false)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  credencial    Credencial @relation(fields: [credencial_id], references: [id], onDelete: Cascade)

  @@index([credencial_id])
  @@map("token_recuperacion")
  @@schema("auth_schema")
}

model PerfilUsuario {
  id                      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  credencial_id           String                 @unique @db.Uuid
  rol                     RolUsuario
  entidad_tipo            String                 @db.VarChar(30)
  entidad_id              String                 @db.Uuid
  created_at              DateTime               @default(now()) @db.Timestamptz(6)
  alumno                  Alumno?
  asistencias_registradas AsistenciaDocente[]
  docente                 Docente?
  situaciones_registradas SituacionFinalAlumno[]
  historial_notas         HistorialNota[]
  sesiones_auditoria      SesionAuditoria[]
  credencial              Credencial             @relation(fields: [credencial_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  boletas_revisadas       BoletaPago[]
  notificaciones          Notificacion[]
  pagos_generados         Pago[]
  horario_publicaciones   HorarioPublicacion[]

  @@index([entidad_tipo, entidad_id], map: "idx_perfil_entidad")
  @@index([rol], map: "idx_perfil_rol")
  @@map("perfil_usuario")
  @@schema("auth_schema")
}

model SesionAuditoria {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuario_id       String              @db.Uuid
  tipo_accion      TipoAccionAuditoria
  modulo           String              @db.VarChar(60)
  entidad_afectada String              @db.VarChar(80)
  entidad_id       String?             @db.Uuid
  old_value        Json?
  new_value        Json?
  ip_origen        String?             @db.Inet
  user_agent       String?
  fecha_hora       DateTime            @default(now()) @db.Timestamptz(6)
  usuario          PerfilUsuario       @relation(fields: [usuario_id], references: [id], onUpdate: NoAction)

  @@index([entidad_afectada, entidad_id], map: "idx_auditoria_entidad")
  @@index([usuario_id, fecha_hora(sort: Desc)], map: "idx_auditoria_usuario")
  @@map("sesion_auditoria")
  @@schema("audit_schema")
}

model InstitucionEducativa {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre              String   @db.VarChar(200)
  codigo_modular      String   @unique @db.VarChar(20)
  codigo_ugel         String   @db.VarChar(10)
  nombre_ugel         String   @db.VarChar(150)
  resolucion_creacion String?  @db.VarChar(100)
  modalidad           String   @default("Educación Básica Regular") @db.VarChar(80)
  gestion             String   @db.VarChar(20)
  departamento        String   @db.VarChar(80)
  provincia           String   @db.VarChar(80)
  distrito            String   @db.VarChar(80)
  centro_poblado      String?  @db.VarChar(100)
  direccion           String?  @db.VarChar(255)
  telefono            String?  @db.VarChar(15)
  email_institucional String?  @db.VarChar(150)
  activo              Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz(6)

  @@map("institucion_educativa")
  @@schema("academic_schema")
}

model Nivel {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String               @unique @db.VarChar(30)
  descripcion    String?
  cursos         Curso[]
  grados         Grado[]
  descansos      HorarioDescanso[]
  horario_config NivelHorarioConfig[]
  areas          AreaAcademica[]

  @@map("nivel")
  @@schema("academic_schema")
}

// Agrupador puramente visual para la libreta (ej. "Matemática" agrupa
// Aritmética/Álgebra/Trigonometría/R.M./Geometría). No participa en
// horario ni asignacion_docente — eso sigue atado a Curso directamente.
model AreaAcademica {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nivel_id   String   @db.Uuid
  nombre     String   @db.VarChar(120)
  orden      Int?     @db.SmallInt
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  nivel      Nivel    @relation(fields: [nivel_id], references: [id], onUpdate: NoAction)
  cursos     Curso[]

  @@unique([nivel_id, nombre])
  @@map("area_academica")
  @@schema("academic_schema")
}

model Grado {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nivel_id            String              @db.Uuid
  nombre              String              @db.VarChar(30)
  orden               Int                 @db.SmallInt
  nivel               Nivel               @relation(fields: [nivel_id], references: [id], onUpdate: NoAction)
  secciones           Seccion[]
  cursos              GradoCurso[]
  simulacro_preguntas SimulacroPregunta[]
  simulacro_examenes  SimulacroExamen[]
  competencias        Competencia[]

  @@unique([nivel_id, orden])
  @@map("grado")
  @@schema("academic_schema")
}

model PeriodoAcademico {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  anio                  Int                    @unique @map("año") @db.SmallInt
  nombre                String                 @db.VarChar(60)
  fecha_inicio          DateTime               @db.Date
  fecha_fin             DateTime               @db.Date
  activo                Boolean                @default(false)
  created_at            DateTime               @default(now()) @db.Timestamptz(6)
  alumnos               Alumno[]
  asignaciones          AsignacionDocente[]
  bimestres             Bimestre[]
  escalas               ConfigEscalaLiteral[]
  secciones             Seccion[]
  situaciones           SituacionFinalAlumno[]
  pagos                 Pago[]
  simulacros            Simulacro[]
  horario_publicaciones HorarioPublicacion[]
  horario_descansos     HorarioDescanso[]
  horario_config        NivelHorarioConfig[]

  @@map("periodo_academico")
  @@schema("academic_schema")
}

model Docente {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  perfil_usuario_id     String               @unique @db.Uuid
  dni                   String               @unique @db.Char(8)
  nombres               String               @db.VarChar(100)
  apellido_paterno      String               @db.VarChar(60)
  apellido_materno      String               @db.VarChar(60)
  fecha_nacimiento      DateTime?            @db.Date
  sexo                  String?              @db.Char(1)
  especialidad          String               @db.VarChar(150)
  titulo_profesional    String?              @db.VarChar(200)
  telefono              String               @db.VarChar(15)
  email_institucional   String?              @unique @db.VarChar(150)
  foto_url              String?
  activo                Boolean              @default(true)
  fecha_ingreso         DateTime?            @db.Date
  created_at            DateTime             @default(now()) @db.Timestamptz(6)
  actividades           Actividad[]
  asignaciones          AsignacionDocente[]
  asistencias_alumnos   Asistencia[]
  asistencias           AsistenciaDocente[]
  perfil                PerfilUsuario        @relation(fields: [perfil_usuario_id], references: [id], onUpdate: NoAction)
  materiales            Material[]
  notas                 Nota[]
  secciones_tutoradas   Seccion[]
  simulacro_preguntas   SimulacroPregunta[]
  horarios              Horario[]
  horario_publicaciones HorarioPublicacion[]

  @@map("docente")
  @@schema("academic_schema")
}

model Seccion {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  grado_id              String               @db.Uuid
  periodo_id            String               @db.Uuid
  nombre                String               @db.VarChar(5)
  turno                 String               @default("Mañana") @db.VarChar(20)
  cupo_maximo           Int                  @db.SmallInt
  docente_tutor_id      String?              @db.Uuid
  aula                  String?              @db.VarChar(20)
  actividades           Actividad[]
  alumnos               Alumno[]
  asignaciones          AsignacionDocente[]
  asistencias           Asistencia[]
  materiales            Material[]
  docente_tutor         Docente?             @relation(fields: [docente_tutor_id], references: [id], onUpdate: NoAction)
  grado                 Grado                @relation(fields: [grado_id], references: [id], onUpdate: NoAction)
  periodo               PeriodoAcademico     @relation(fields: [periodo_id], references: [id], onUpdate: NoAction)
  simulacro_preguntas   SimulacroPregunta[]
  horarios              Horario[]
  horario_publicaciones HorarioPublicacion[]

  @@unique([grado_id, periodo_id, nombre])
  @@map("seccion")
  @@schema("academic_schema")
}

model Alumno {
  id                  String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  perfil_usuario_id   String                 @unique @db.Uuid
  seccion_id          String                 @db.Uuid
  periodo_id          String                 @db.Uuid
  dni                 String                 @unique @db.Char(8)
  codigo_siagie       String?                @unique @db.VarChar(20)
  nombres             String                 @db.VarChar(100)
  apellido_paterno    String                 @db.VarChar(60)
  apellido_materno    String                 @db.VarChar(60)
  fecha_nacimiento    DateTime               @db.Date
  sexo                String                 @db.Char(1)
  foto_url            String?
  direccion           String?                @db.VarChar(255)
  distrito            String?                @db.VarChar(100)
  telefono_emergencia String?                @db.VarChar(15)
  grupo_sanguineo     String?                @db.VarChar(5)
  condicion_especial  String?
  bloqueo_manual      Boolean                @default(false)
  activo              Boolean                @default(true)
  created_at          DateTime               @default(now()) @db.Timestamptz(6)
  perfil              PerfilUsuario          @relation(fields: [perfil_usuario_id], references: [id], onUpdate: NoAction)
  periodo             PeriodoAcademico       @relation(fields: [periodo_id], references: [id], onUpdate: NoAction)
  seccion             Seccion                @relation(fields: [seccion_id], references: [id], onUpdate: NoAction)
  asistencias         Asistencia[]
  entregas            EntregaActividad[]
  notas               Nota[]
  situaciones         SituacionFinalAlumno[]
  pagos               Pago[]

  @@unique([dni, periodo_id])
  @@index([codigo_siagie], map: "idx_alumno_codigo_siagie")
  @@index([dni], map: "idx_alumno_dni")
  @@index([seccion_id, periodo_id], map: "idx_alumno_seccion_periodo")
  @@map("alumno")
  @@schema("academic_schema")
}

model AsistenciaDocente {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  docente_id     String           @db.Uuid
  registrado_por String           @db.Uuid
  fecha          DateTime         @db.Date
  estado         EstadoAsistencia
  justificacion  String?
  hora_registro  DateTime         @default(now()) @db.Timestamptz(6)
  docente        Docente          @relation(fields: [docente_id], references: [id], onUpdate: NoAction)
  registrador    PerfilUsuario    @relation(fields: [registrado_por], references: [id], onUpdate: NoAction)

  @@unique([docente_id, fecha])
  @@index([docente_id, fecha], map: "idx_asistencia_docente")
  @@map("asistencia_docente")
  @@schema("academic_schema")
}

model Bimestre {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  periodo_id   String           @db.Uuid
  numero       Int              @db.SmallInt
  nombre       String           @db.VarChar(40)
  fecha_inicio DateTime         @db.Date
  fecha_fin    DateTime         @db.Date
  cerrado      Boolean          @default(false)
  periodo      PeriodoAcademico @relation(fields: [periodo_id], references: [id], onUpdate: NoAction)
  notas        Nota[]
  simulacros   Simulacro[]

  @@unique([periodo_id, numero])
  @@index([periodo_id, numero], map: "idx_bimestre_periodo")
  @@map("bimestre")
  @@schema("academic_schema")
}

model Curso {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nivel_id            String              @db.Uuid
  nombre              String              @db.VarChar(120)
  codigo_cneb         String?             @db.VarChar(20)
  descripcion         String?
  horas_semanales     Int?                @db.SmallInt
  area_academica_id   String?             @db.Uuid
  actividades         Actividad[]
  asignaciones        AsignacionDocente[]
  competencias        Competencia[]
  nivel               Nivel               @relation(fields: [nivel_id], references: [id], onUpdate: NoAction)
  area_academica      AreaAcademica?      @relation(fields: [area_academica_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  materiales          Material[]
  grados              GradoCurso[]
  simulacro_preguntas SimulacroPregunta[]
  simulacro_examenes  SimulacroExamen[]

  @@unique([nivel_id, nombre])
  @@map("curso")
  @@schema("academic_schema")
}

// ============================================================
//  Módulo Simulacro de Admisión
// ============================================================
enum EstadoSimulacro {
  Borrador
  Activo
  Concluido

  @@map("estado_simulacro")
  @@schema("academic_schema")
}

// Instancia de simulacro de admisión. Opcionalmente ligado a un bimestre
// (cada bimestre puede tener el suyo, no obligatorio). Máx. 4 por período.
// Solo uno puede estar Activo a la vez (índice único parcial en el DDL).
model Simulacro {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  periodo_id  String              @db.Uuid
  bimestre_id String?             @db.Uuid
  numero      Int                 @db.SmallInt
  nombre      String              @db.VarChar(60)
  estado      EstadoSimulacro     @default(Borrador)
  created_by  String?             @db.Uuid
  created_at  DateTime            @default(now()) @db.Timestamptz(6)
  periodo     PeriodoAcademico    @relation(fields: [periodo_id], references: [id], onUpdate: NoAction)
  bimestre    Bimestre?           @relation(fields: [bimestre_id], references: [id], onUpdate: NoAction)
  preguntas   SimulacroPregunta[]
  examenes    SimulacroExamen[]

  @@unique([periodo_id, numero])
  @@map("simulacro")
  @@schema("academic_schema")
}

// Banco de preguntas que suben los docentes (por curso y grado).
model SimulacroPregunta {
  id                 String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  simulacro_id       String?                   @db.Uuid
  docente_id         String                    @db.Uuid
  curso_id           String                    @db.Uuid
  grado_id           String                    @db.Uuid
  seccion_id         String?                   @db.Uuid
  enunciado          String
  imagen_url         String?
  alt_a              String
  alt_b              String
  alt_c              String
  alt_d              String
  alt_e              String
  respuesta_correcta String                    @db.Char(1)
  orden              Int                       @db.SmallInt
  created_at         DateTime                  @default(now()) @db.Timestamptz(6)
  simulacro          Simulacro?                @relation(fields: [simulacro_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  docente            Docente                   @relation(fields: [docente_id], references: [id], onUpdate: NoAction)
  curso              Curso                     @relation(fields: [curso_id], references: [id], onUpdate: NoAction)
  grado              Grado                     @relation(fields: [grado_id], references: [id], onUpdate: NoAction)
  seccion            Seccion?                  @relation(fields: [seccion_id], references: [id], onUpdate: NoAction)
  examen_items       SimulacroExamenPregunta[]

  @@index([simulacro_id, grado_id, curso_id])
  @@map("simulacro_pregunta")
  @@schema("academic_schema")
}

// Examen oficial por grado + curso (curado por Admin). El `orden` define la
// posición del curso en el cuestionario y la numeración del balotario.
model SimulacroExamen {
  id           String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  simulacro_id String                    @db.Uuid
  grado_id     String                    @db.Uuid
  curso_id     String                    @db.Uuid
  orden        Int                       @db.SmallInt
  simulacro    Simulacro                 @relation(fields: [simulacro_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  grado        Grado                     @relation(fields: [grado_id], references: [id], onUpdate: NoAction)
  curso        Curso                     @relation(fields: [curso_id], references: [id], onUpdate: NoAction)
  preguntas    SimulacroExamenPregunta[]

  @@unique([simulacro_id, grado_id, curso_id])
  @@unique([simulacro_id, grado_id, orden])
  @@map("simulacro_examen")
  @@schema("academic_schema")
}

// Las exactamente 5 preguntas seleccionadas para un examen (grado+curso).
// Guarda un SNAPSHOT del contenido: el examen armado es un documento inmutable
// que no se rompe si luego el docente edita o borra la pregunta del banco.
model SimulacroExamenPregunta {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examen_id          String             @db.Uuid
  pregunta_id        String?            @db.Uuid
  orden              Int                @db.SmallInt
  enunciado          String?
  imagen_url         String?
  alt_a              String?
  alt_b              String?
  alt_c              String?
  alt_d              String?
  alt_e              String?
  respuesta_correcta String?            @db.Char(1)
  examen             SimulacroExamen    @relation(fields: [examen_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pregunta           SimulacroPregunta? @relation(fields: [pregunta_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([examen_id, orden])
  @@unique([examen_id, pregunta_id])
  @@map("simulacro_examen_pregunta")
  @@schema("academic_schema")
}

// Cursos asignados a un grado concreto (override de los cursos por nivel).
// Al crear un grado se copian los cursos de su nivel como predeterminados;
// luego se editan por grado. Las secciones heredan los cursos de su grado.
model GradoCurso {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  grado_id   String   @db.Uuid
  curso_id   String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  grado      Grado    @relation(fields: [grado_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  curso      Curso    @relation(fields: [curso_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([grado_id, curso_id])
  @@map("grado_curso")
  @@schema("academic_schema")
}

model Competencia {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  curso_id    String  @db.Uuid
  grado_id    String? @db.Uuid
  nombre      String  @db.VarChar(200)
  descripcion String?
  tipo        String  @db.VarChar(20)
  orden       Int?    @db.SmallInt
  peso        Decimal @default(100.00) @db.Decimal(5, 2)
  curso       Curso   @relation(fields: [curso_id], references: [id], onUpdate: NoAction)
  grado       Grado?  @relation(fields: [grado_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  notas       Nota[]

  @@map("competencia")
  @@schema("academic_schema")
}

model AsignacionDocente {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  docente_id String           @db.Uuid
  curso_id   String           @db.Uuid
  seccion_id String           @db.Uuid
  periodo_id String           @db.Uuid
  activo     Boolean          @default(true)
  created_at DateTime         @default(now()) @db.Timestamptz(6)
  curso      Curso            @relation(fields: [curso_id], references: [id], onUpdate: NoAction)
  docente    Docente          @relation(fields: [docente_id], references: [id], onUpdate: NoAction)
  periodo    PeriodoAcademico @relation(fields: [periodo_id], references: [id], onUpdate: NoAction)
  seccion    Seccion          @relation(fields: [seccion_id], references: [id], onUpdate: NoAction)
  horarios   Horario[]

  @@unique([docente_id, seccion_id, curso_id, periodo_id])
  @@map("asignacion_docente")
  @@schema("academic_schema")
}

model Horario {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  asignacion_id String            @db.Uuid
  dia_semana    Int               @db.SmallInt
  hora_inicio   DateTime          @db.Time(6)
  hora_fin      DateTime          @db.Time(6)
  aula          String?           @db.VarChar(20)
  docente_id    String            @db.Uuid
  seccion_id    String            @db.Uuid
  asignacion    AsignacionDocente @relation(fields: [asignacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  docente       Docente           @relation(fields: [docente_id], references: [id], onUpdate: NoAction)
  seccion       Seccion           @relation(fields: [seccion_id], references: [id], onUpdate: NoAction)

  @@index([asignacion_id, dia_semana, hora_inicio], map: "idx_horario_asignacion")
  @@index([docente_id], map: "idx_horario_docente_id")
  @@index([seccion_id], map: "idx_horario_seccion_id")
  @@map("horario")
  @@schema("academic_schema")
}

// Snapshot vigente (sin historial) del horario publicado a un Docente o a una
// Sección. Desacoplado del borrador editable (Horario): republicar sobrescribe
// tipo y sus bloques, los cambios del borrador no se ven hasta re-publicar.
model HorarioPublicacion {
  id                String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo              String                     @db.VarChar(10)
  docente_id        String?                    @db.Uuid
  seccion_id        String?                    @db.Uuid
  periodo_id        String                     @db.Uuid
  publicado_por     String                     @db.Uuid
  fecha_publicacion DateTime                   @default(now()) @db.Timestamptz(6)
  docente           Docente?                   @relation(fields: [docente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  seccion           Seccion?                   @relation(fields: [seccion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  periodo           PeriodoAcademico           @relation(fields: [periodo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  publicador        PerfilUsuario              @relation(fields: [publicado_por], references: [id], onUpdate: NoAction)
  bloques           HorarioPublicacionBloque[]

  @@map("horario_publicacion")
  @@schema("academic_schema")
}

// Bloques del snapshot publicado, desnormalizados: no cambian si el borrador
// se edita después de publicar. Sin FK viva hacia Horario (horario_id_origen
// es solo informativo, el bloque vivo puede editarse o borrarse después).
model HorarioPublicacionBloque {
  id                      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicacion_id          String             @db.Uuid
  horario_id_origen       String?            @db.Uuid
  dia_semana              Int                @db.SmallInt
  hora_inicio             DateTime           @db.Time(6)
  hora_fin                DateTime           @db.Time(6)
  aula_snapshot           String?            @db.VarChar(20)
  curso_nombre_snapshot   String             @db.VarChar(120)
  docente_nombre_snapshot String             @db.VarChar(160)
  seccion_nombre_snapshot String             @db.VarChar(20)
  grado_nombre_snapshot   String             @db.VarChar(30)
  nivel_nombre_snapshot   String             @db.VarChar(30)
  publicacion             HorarioPublicacion @relation(fields: [publicacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([publicacion_id], map: "idx_horario_publicacion_bloque_publicacion")
  @@map("horario_publicacion_bloque")
  @@schema("academic_schema")
}

// Recreo y Refrigerio/Almuerzo por Nivel y período, mismo horario Lun-Vie
// para Docentes y Alumnos. Sin relación con docente_id/seccion_id a
// propósito: no es un bloque de clase, no participa de las EXCLUDE
// constraints ni del trigger de cruces de Horario. Sin flujo de
// publicación: se sirve siempre en vivo, upsert por (nivel_id, periodo_id, tipo).
model HorarioDescanso {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nivel_id    String           @db.Uuid
  periodo_id  String           @db.Uuid
  tipo        String           @db.VarChar(12)
  hora_inicio DateTime         @db.Time(6)
  hora_fin    DateTime         @db.Time(6)
  nivel       Nivel            @relation(fields: [nivel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  periodo     PeriodoAcademico @relation(fields: [periodo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([nivel_id, periodo_id, tipo])
  @@map("horario_descanso")
  @@schema("academic_schema")
}

// Jornada escolar por nivel: hora de inicio y duración (min) de una
// "hora escolar" — los bloques de Horario se generan sumando esta
// duración desde hora_inicio_jornada, con Recreo/Refrigerio como
// anclas fijas que reinician la suma. Ver backend/lib/horario-slots.ts.
model NivelHorarioConfig {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nivel_id            String           @db.Uuid
  periodo_id          String           @db.Uuid
  hora_inicio_jornada DateTime         @db.Time(6)
  duracion_hora_min   Int              @db.SmallInt
  total_horas_dia     Int              @default(8) @db.SmallInt
  nivel               Nivel            @relation(fields: [nivel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  periodo             PeriodoAcademico @relation(fields: [periodo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([nivel_id, periodo_id])
  @@map("nivel_horario_config")
  @@schema("academic_schema")
}

model ConfigEscalaLiteral {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  periodo_id     String           @db.Uuid
  escala         NotaLiteral
  rango_inferior Decimal          @db.Decimal(4, 2)
  rango_superior Decimal          @db.Decimal(4, 2)
  periodo        PeriodoAcademico @relation(fields: [periodo_id], references: [id], onUpdate: NoAction)

  @@unique([periodo_id, escala])
  @@map("config_escala_literal")
  @@schema("academic_schema")
}

model Nota {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alumno_id       String          @db.Uuid
  competencia_id  String          @db.Uuid
  bimestre_id     String          @db.Uuid
  docente_id      String          @db.Uuid
  nota_vigesimal  Decimal         @db.Decimal(4, 2)
  nota_literal    NotaLiteral
  tipo_evaluacion TipoEvaluacion  @default(Final)
  cerrada         Boolean         @default(false)
  observacion     String?
  fecha_registro  DateTime        @default(now()) @db.Timestamptz(6)
  alumno          Alumno          @relation(fields: [alumno_id], references: [id], onUpdate: NoAction)
  bimestre        Bimestre        @relation(fields: [bimestre_id], references: [id], onUpdate: NoAction)
  competencia     Competencia     @relation(fields: [competencia_id], references: [id], onUpdate: NoAction)
  docente         Docente         @relation(fields: [docente_id], references: [id], onUpdate: NoAction)
  historial       HistorialNota[]

  @@unique([alumno_id, competencia_id, bimestre_id])
  @@index([alumno_id, bimestre_id, competencia_id], map: "idx_nota_alumno_bimestre")
  @@index([docente_id], map: "idx_nota_docente")
  @@index([tipo_evaluacion], map: "idx_nota_tipo_evaluacion")
  @@map("nota")
  @@schema("academic_schema")
}

model SituacionFinalAlumno {
  id                        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alumno_id                 String           @db.Uuid
  periodo_id                String           @db.Uuid
