model Actividad {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  docente_id       String             @db.Uuid
  curso_id         String             @db.Uuid
  seccion_id       String             @db.Uuid
  titulo           String             @db.VarChar(200)
  descripcion      String?
  tipo             TipoActividad?
  fecha_asignacion DateTime           @default(now()) @db.Timestamptz(6)
  fecha_limite     DateTime           @db.Timestamptz(6)
  puntaje_maximo   Decimal            @db.Decimal(5, 2)
  url_adjunto      String?
  curso            Curso              @relation(fields: [curso_id], references: [id], onUpdate: NoAction)
  docente          Docente            @relation(fields: [docente_id], references: [id], onUpdate: NoAction)
  seccion          Seccion            @relation(fields: [seccion_id], references: [id], onUpdate: NoAction)
  entregas         EntregaActividad[]

  @@index([seccion_id, curso_id], map: "idx_actividad_seccion")
