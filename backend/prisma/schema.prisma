  comportamiento            String?          @db.VarChar(10)
  motivo_retiro             String?
  observaciones             String?
  registrado_por            String           @db.Uuid
  fecha_registro            DateTime         @default(now()) @db.Timestamptz(6)
  alumno                    Alumno           @relation(fields: [alumno_id], references: [id], onUpdate: NoAction)
  periodo                   PeriodoAcademico @relation(fields: [periodo_id], references: [id], onUpdate: NoAction)
  registrador               PerfilUsuario    @relation(fields: [registrado_por], references: [id], onUpdate: NoAction)

  @@unique([alumno_id, periodo_id])
  @@index([alumno_id, periodo_id], map: "idx_situacion_final")
  @@map("situacion_final_alumno")
  @@schema("academic_schema")
}

model Asistencia {
